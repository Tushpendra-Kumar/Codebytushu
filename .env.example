# ─────────────────────────────────────────────────────────────
# CodeByTushu — .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME="CodeByTushu"
APP_ENV=local
# Set to 'production' on live server
APP_DEBUG=true
SITE_URL=http://localhost

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=codebytushu
DB_USER=root
DB_PASS=

# ── Session ──────────────────────────────────────────────────
SESSION_NAME=CBT_SESSION
SESSION_LIFETIME=86400
SESSION_SECURE=false
# Set to true on HTTPS in production

# ── CSRF ─────────────────────────────────────────────────────
CSRF_TOKEN_LENGTH=32

# ── SMTP / Email ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME="CodeByTushu"
SMTP_TO_EMAIL=your@gmail.com
# For Hostinger: smtp.hostinger.com, port 465

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=/absolute/path/to/codebytushu/uploads
UPLOAD_MAX_IMAGE=5242880
# 5MB in bytes
UPLOAD_MAX_PDF=20971520
# 20MB
UPLOAD_MAX_VIDEO=524288000
# 500MB
UPLOAD_MAX_ZIP=104857600
# 100MB

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google-callback.php

# ── Razorpay Payment ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Security ─────────────────────────────────────────────────
PASSWORD_BCRYPT_COST=12
REMEMBER_ME_DAYS=30
RESET_TOKEN_EXPIRY=3600
# 1 hour in seconds
VERIFY_TOKEN_EXPIRY=86400
# 24 hours

# ── Rate Limiting ────────────────────────────────────────────
CONTACT_RATE_LIMIT=3
# Max contact form submissions per hour per IP
LOGIN_MAX_ATTEMPTS=5
# Max failed logins before lockout
LOGIN_LOCKOUT_MINUTES=15
