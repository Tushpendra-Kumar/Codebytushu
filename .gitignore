# ─────────────────────────────────────────────
#   CodeByTushu — .gitignore
# ─────────────────────────────────────────────

# NOTE: firebase-config.js is SAFE to commit.
# Firebase API keys are public project identifiers — not secrets.
# Real security = Firebase Auth rules (server-side).

# Environment secrets (if ever added)
.env
.env.local
.env.*.local

# Node / npm (if ever used)
node_modules/
package-lock.json
npm-debug.log*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor artifacts
.vscode/settings.json
.idea/
*.suo
*.user

# Build output (if added later)
/dist/
/build/

# ─── PHP Migration additions ──────────────────
# PHP Composer
/vendor/
composer.lock

# Uploaded user files (never commit)
/uploads/images/
/uploads/pdfs/
/uploads/videos/
/uploads/zips/
/uploads/misc/
/uploads/blog/
/uploads/courses/
/uploads/avatars/

# Maintenance flag
/private/.maintenance

# PHP error logs
*.log
error_log
